<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" />
    </configSections>

    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
    </startup>

    <appSettings>
        <add key="PhotoRootPath" value="D:\Photo"/>
        <add key="CameraIndex" value="0"/>
        <add key="MaxPhotoCount" value="5"/>
        <add key="DatabasePath" value="CameraData.db"/>
        <!-- 解析度設定：3840 為 4K, 1920 為 1080p -->
        <add key="DesiredWidth" value="3840"/>
    </appSettings>

    <log4net>
        <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">
            <!-- 設定 Log 存放的主目錄 -->
            <file value="Logs\" />
            <appendToFile value="true" />
            <rollingStyle value="Date" />
            <!-- 設定以天為單位產生資料夾，並在資料夾內生成 log.txt -->
            <datePattern value="yyyy-MM-dd'\\log.txt'" />
            <!-- 如果設為 false，則檔名會包含 datePattern -->
            <staticLogFileName value="false" />
            <layout type="log4net.Layout.PatternLayout">
                <conversionPattern value="[%date{HH:mm:ss}] [%thread] %-5level - %message%newline" />
            </layout>
        </appender>
        <root>
            <level value="ALL" />
            <appender-ref ref="RollingFile" />
        </root>
    </log4net>
</configuration>
